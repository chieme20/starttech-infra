{
  "Alarms": [
    {
      "AlarmName": "starttech-high-cpu-alarm",
      "MetricName": "CPUUtilization",
      "Namespace": "AWS/EC2",
      "Statistic": "Average",
      "Period": 300,
      "EvaluationPeriods": 2,
      "Threshold": 80.0,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "AlarmDescription": "Triggers scale-out event if ASG CPU exceeds 80% threshold."
    }
  ]
}